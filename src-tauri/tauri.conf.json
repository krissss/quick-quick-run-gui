{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "QQRun",
  "version": "0.2.0",
  "identifier": "com.quick-quick-run.gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src * data: blob: 'unsafe-inline' 'unsafe-eval'; script-src * 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src * data: blob:; img-src * data: blob:; style-src * 'unsafe-inline' data: blob:; font-src * data: blob:; frame-src * data: blob:; frame-ancestors *; media-src * data: blob:; object-src * data: blob:; worker-src * data: blob:;"
    },
    "windows": [
      {
        "title": "QQRun",
        "width": 1180,
        "height": 760,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#ffffff"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwQUQyQkIyQzRDNEQ5MDEKUldRQjJjVEVzaXV0TUVWMldPbDRZVVRhcG1yc0lPb0paTlFTZCtlakNoSmt4Rm5odWx1Qmh1bVMK",
      "endpoints": [
        "https://github.com/krissss/quick-quick-run-gui/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
