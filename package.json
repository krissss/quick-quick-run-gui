{
  "name": "quick-quick-run-gui",
  "version": "0.1.0",
  "description": "Tauri desktop runner for local web apps, services, and scheduled tasks.",
  "author": "kriss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krissss/quick-quick-run-gui.git"
  },
  "bugs": {
    "url": "https://github.com/krissss/quick-quick-run-gui/issues"
  },
  "homepage": "https://github.com/krissss/quick-quick-run-gui#readme",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:rust && pnpm test:e2e:frontend",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:frontend": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm test:e2e:frontend",
    "test:e2e:frontend": "playwright test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5"
  }
}
